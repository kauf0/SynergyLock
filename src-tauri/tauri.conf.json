{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SynergyLock",
  "version": "1.0.0",
  "identifier": "com.deadlock.synergy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SynergyLock",
        "width": 480,
        "height": 700,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true,
        "fullscreen": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
